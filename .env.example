# CDSS Database Configuration
DATABASE_HOST=your_postgres_host
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_URL=postgresql+asyncpg://postgres:your_password_here@your_postgres_host:5432/postgres

# Connection Pool Settings
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_POOL_MAX_QUERIES=50000
DB_POOL_MAX_INACTIVE_CONNECTION_LIFETIME=300

# Postgres admin (for schema migrations / superuser ops)
POSTGRES_PASSWORD=your_password_here

# Shared DB credentials used by pipeline scripts
DB_HOST=your_postgres_host
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_password_here

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# External API keys
HF_TOKEN=your_huggingface_token_here
RUNPOD_API_KEY=your_runpod_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
DEEPINFRA_API_KEY=your_deepinfra_api_key_here

# vLLM Endpoints (fill in Phase 3)
VLLM_EXTRACTION_URL=
VLLM_COMPOSITION_URL=
VLLM_EMBEDDING_URL=

# Postgres admin for drugdb ops
PG_HOST=your_postgres_host
PG_PORT=5432
PG_DB=postgres
PG_USER=postgres
PG_PASSWORD=your_password_here

# Dry run mode for fix scripts
DRY_RUN=false
